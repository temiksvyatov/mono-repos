{% extends "common/templates/Dockerfile.common.j2" %}
{% block package_installation %}
USER 0
RUN rm -f /etc/yum.repos.d/* && \
    curl --connect-timeout 30 --fail https://repo.nexign.com/scripts/add-ubi9-repo.sh | sh && \
    curl --connect-timeout 30 --fail https://repo.nexign.com/scripts/add-elrepo-repo.sh | sh && \
    update-ca-trust force-enable && \
    update-ca-trust extract && \
    {{ package_manager }} install -y --nodocs {{ packages | join(' ') }} && \
    {{ package_manager }} clean all
{% endblock %}
{% block specific %}
ENV APP_ROOT=/opt/app-root
ENV PATH=/opt/app-root/src/bin:/opt/app-root/bin:$HOME/.local/bin/:$PATH \
    PYTHONUNBUFFERED=1 \
    PYTHONIOENCODING=UTF-8 \
    PIP_NO_CACHE_DIR=off \
    PYTHON_FULL_VERSION={{python_full_version}} \
    PYTHON_MINOR_VERSION={{python_minor_version}} \
    PYTHON_REGISTRY={{python_registry}}

USER 0

RUN useradd -m -u 11200 mf-user -s /bin/bash && \
    mkdir -p /data/app && \
    chown mf-user:mf-user /data/app

COPY images/python/build-python.sh /tmp/build-python.sh
RUN chmod +x /tmp/build-python.sh

# Build Python from source. The Artifactory API token is injected via BuildKit
# secret mount and never appears in any image layer.
RUN --mount=type=secret,id=tok /tmp/build-python.sh && rm /tmp/build-python.sh
{% endblock %}
{% block post_install %}
{% endblock %}
