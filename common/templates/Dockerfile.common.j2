{% macro install_packages(manager, pkgs) -%}
{%- if manager == 'apk' %}
USER 0
RUN apk add --no-cache {{ pkgs | join(' ') }}
{%- elif manager == 'microdnf' %}
RUN microdnf install -y --nodocs {{ pkgs | join(' ') }}
{%- elif manager == 'dnf' %}
RUN dnf install -y --nodocs {{ pkgs | join(' ') }}
{%- else %}
{# Unsupported package_manager: {{ manager }} — extend install_packages macro to add support #}
{%- endif %}
{%- endmacro %}
FROM {{ base_image }} AS runtime
LABEL NAME={{ name }}
{# Copying general files #}
{% for copy_item in copy %}
COPY {{ copy_item.source }} {{ copy_item.dest }}
{% endfor %}
{# Prepare alpine repos #}
{% block alpine_repo_setup %}{% endblock %}
{# Setup packages — package manager selection is centralised in the install_packages macro above #}
{% block package_installation %}
{{ install_packages(package_manager, packages) }}
{% endblock %}
{# Post-installation steps #}
{% block post_install %}
    {% for run_cmd in run %}
        RUN {{ run_cmd }}
    {% endfor %}
{% endblock %}
{# User creation #}
{% if users %}
RUN {% for user in users %} adduser -u {{ user.uid }} {{ user.name }} -D {% if not loop.last %} && {% endif %}{% endfor %}
{% endif %}
{# ENVs setup #}
{% for key, value in env.items() %}
ENV {{ key }}='{{ value }}'
{% endfor %}
{% block extra_env %}{% endblock %}
WORKDIR {{ workdir }}
USER {{ user }}
{# Specific image instructions #}
{% block specific %}{% endblock %}
